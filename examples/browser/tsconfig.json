{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "paths": {
      "piebox/browser": ["../../src/browser.ts"],
      "piebox/layer2": ["../../src/layer2/index.ts"],
      "@piebox/driver-agent": ["../../packages/driver-agent/src/index.ts"],
      "@pyric/ui/agents": ["./vendor/pyric-ui/agents/index.ts"],
      "@pyric/ui/primitives": ["./vendor/pyric-ui/primitives/index.ts"]
    }
  },
  "include": ["src", "vendor", "vite.config.ts"]
}
