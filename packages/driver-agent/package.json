{
  "name": "@piebox/driver-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Agent-loop driver for piebox sandboxes. Adapts an LLM client to the Layer 2 surface (piebox/layer2).",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@inbrowser/agent": "^0.1.0",
    "@inbrowser/relay": "^0.1.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "just-bash": "^3.0.1",
    "piebox": "*"
  },
  "engines": {
    "node": ">=22"
  }
}
