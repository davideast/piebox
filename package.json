{
  "name": "piebox",
  "version": "0.1.0",
  "description": "Lightweight in-memory sandbox environment for agent execution",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "piebox": "./dist/cli/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build-cli": "npx tsx build-cli.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "sandbox",
    "agent",
    "in-memory",
    "virtual-filesystem",
    "vfs",
    "ai-agent",
    "isomorphic-git",
    "bash"
  ],
  "author": "David East",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "@platformatic/vfs": "^0.4.0",
    "citty": "^0.1.6",
    "diff": "^9.0.0",
    "isomorphic-git": "^1.37.8",
    "just-bash": "^3.0.1",
    "niftty": "^0.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "typescript": "^5.8.3",
    "vitest": "^2.1.2"
  }
}
